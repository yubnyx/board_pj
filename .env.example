# 이 파일을 backend/.env 로 복사한 뒤 값을 채워주세요.
#   cp .env.example backend/.env

# ===== 데이터베이스 (FastAPI 백엔드용) =====
# 도커로 띄울 땐 DB_HOST/DB_PORT 는 docker-compose 가 "db:3306" 으로 덮어씌웁니다.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=board_db

# ===== MySQL 컨테이너 부트스트랩용 =====
# mysql:8.0 공식 이미지가 첫 기동 시 사용합니다.
# DB_PASSWORD / DB_NAME 와 값이 같아야 백엔드가 접속할 수 있습니다.
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=board_db

# ===== OpenRouter (벡터 임베딩) =====
# https://openrouter.ai 에서 발급
OPENROUTER_API_KEY=
